# Keep this file plain ASCII and free of angle brackets.
# Replit's TOML parser rejected this file when the comments contained em-dashes,
# emoji, and a URL placeholder in angle brackets. See REPLIT.md for the
# explanation that used to live here.

run = "npm run replit"
entrypoint = "app/_layout.tsx"
modules = ["nodejs-20"]

hidden = [".expo", "node_modules", "dist", ".git"]

[nix]
channel = "stable-24_05"

[env]
EXPO_NO_TELEMETRY = "1"
NODE_OPTIONS = "--max-old-space-size=2048"

# Expo's web dev server is fixed to 8081. The --port flag does not apply to web.
[[ports]]
localPort = 8081
externalPort = 80

[deployment]
build = ["sh", "-c", "npx expo export --platform web"]
run = ["sh", "-c", "npx serve dist --listen 8081 --single"]
deploymentTarget = "autoscale"

[languages.typescript]
pattern = "**/*.{ts,tsx}"

[languages.typescript.languageServer]
start = "typescript-language-server --stdio"
