# Replit runs Linux, so there is no iOS or Android simulator here. What Replit
# CAN run is the web build — which is the same app, and the one a transport
# coordinator would use at a desk anyway (blueprint §7.3).
#
# Collaborators: open the Secrets tab (🔒) and add the two Supabase values before
# pressing Run. Without them the app boots to a "Connect Supabase" screen rather
# than crashing, so it is obvious what is missing.
#
#   EXPO_PUBLIC_SUPABASE_URL              https://<project-ref>.supabase.co
#   EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY  sb_publishable_...
#
# Both are safe to share with collaborators: the publishable key grants nothing
# on its own. Row Level Security decides what each signed-in user can read, and
# Postgres enforces it no matter who holds the key. Never put the SECRET /
# service_role key here — that one bypasses RLS entirely.

run = "npm run replit"
entrypoint = "app/_layout.tsx"
modules = ["nodejs-20"]

hidden = [".expo", "node_modules", "dist", ".git"]

[nix]
channel = "stable-24_05"

[env]
EXPO_NO_TELEMETRY = "1"

# Metro spawns a worker per CPU core and each one is hungry. On a Replit
# container that is a good way to get the bundler OOM-killed halfway through a
# 1,800-module build — which looks exactly like the app "hanging" on a spinner,
# because the bundle never arrives. `--max-workers 2` in the `replit` script caps
# it. Slower to build, but it finishes.
#
# Node's default heap is also smaller than this bundle wants.
NODE_OPTIONS = "--max-old-space-size=2048"

# Expo's web dev server is fixed to 8081 (`--port` explicitly does not apply to
# web), so that is what gets forwarded.
[[ports]]
localPort = 8081
externalPort = 80

[deployment]
# A published Replit serves the static export rather than running Metro — much
# faster to load, and it does not need a bundler running to answer a request.
build = ["sh", "-c", "npx expo export --platform web"]
run = ["sh", "-c", "npx serve dist --listen 8081 --single"]
deploymentTarget = "autoscale"

[languages.typescript]
pattern = "**/*.{ts,tsx}"

[languages.typescript.languageServer]
start = "typescript-language-server --stdio"
