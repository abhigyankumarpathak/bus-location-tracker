# Keep this file plain ASCII and free of angle brackets.
#
# HOW THIS RUNS, AND WHY
#
# Replit's Preview pane and the iPhone "Simulate on Web" frame only look at
# port 5000. Expo's DEV server cannot move off 8081 -- the --port flag explicitly
# does not apply to web -- so the two cannot be reconciled while Metro is
# serving.
#
# They do not need to be. `expo export --platform web` produces a plain static
# site in dist/, and static files can be served on any port at all. So Replit
# gets port 5000, and Metro is not running here at all.
#
# That also removes the memory pressure: Metro is what was at risk of being
# OOM-killed on a small container. Serving files is not.
#
# The tradeoff: no hot reload. A code change needs another Run to rebuild. For
# showing the app to collaborators -- which is what Replit is for here -- that is
# the right trade. For live editing, use `npm run replit:dev` in the Shell, which
# runs Metro on 8081; reach it via the .replit.dev URL rather than the Preview.

run = "npm run replit"
entrypoint = "app/_layout.tsx"
modules = ["nodejs-20"]

hidden = [".expo", "node_modules", "dist", ".git"]

[nix]
channel = "stable-24_05"

[env]
EXPO_NO_TELEMETRY = "1"
NODE_OPTIONS = "--max-old-space-size=2048"

# Only needed by replit:dev. `expo start --web` tries to open a browser, which on
# a Linux container means xdg-open, which does not exist -- so Expo crashes
# before serving anything. This tells it not to bother.
BROWSER = "none"

# Port 5000 is what Replit's Preview and the mobile frame watch. Nothing else
# works, so the static build is served here.
[[ports]]
localPort = 5000
externalPort = 80

[workflows]
runButton = "Run app"

[[workflows.workflow]]
name = "Run app"
author = "repo"
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run replit"
waitForPort = 5000

[deployment]
build = ["sh", "-c", "npx expo export --platform web"]
run = ["sh", "-c", "npx serve dist --listen 5000 --single"]
deploymentTarget = "autoscale"

[languages.typescript]
pattern = "**/*.{ts,tsx}"

[languages.typescript.languageServer]
start = "typescript-language-server --stdio"
